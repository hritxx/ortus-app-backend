// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id       String  @id @default(cuid())
    email    String  @unique
    password String
    name     String?
    phone    String? @unique

    // KYC Information
    panNumber     String? @unique
    aadhaarNumber String? @unique
    address       String?
    city          String?
    state         String?
    pincode       String?
    dateOfBirth   String?

    // Professional Information
    occupation   String?
    annualIncome String?

    // Bank Details
    bankAccount   String?
    ifscCode      String?
    bankName      String?
    accountHolder String?

    // Token Balance
    tokenBalance Int @default(0)

    // Status & Verification
    kycStatus        KycStatus @default(PENDING)
    emailVerified    Boolean   @default(false)
    phoneVerified    Boolean   @default(false)
    twoFactorEnabled Boolean   @default(false)
    isActive         Boolean   @default(true)

    // Refresh Token for JWT
    refreshToken String?

    // Metadata
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    lastLoginAt DateTime?

    // Relations
    investments        Investment[]
    transactions       Transaction[]
    notifications      Notification[]
    devices            Device[]
    otpVerifications   OtpVerification[]
    auditLogs          AuditLog[]
    portfolioSnapshots PortfolioSnapshot[]
    tokenTransactions  TokenTransaction[]

    // NEW Relations for Courses, Consultancy, and Channels
    courseEnrollments        CourseEnrollment[]
    consultancySubscriptions ConsultancySubscription[]
    oneOnOneSessions         OneOnOneSession[]

    @@index([email])
    @@index([phone])
    @@index([panNumber])
    @@index([aadhaarNumber])
    @@map("users")
}

model InvestmentPlan {
    id                String         @id @default(cuid())
    name              String
    professionalTitle String
    type              InvestmentType
    interestRate      Float
    minimumInvestment Float
    maximumInvestment Float?
    lockInPeriod      Int // in months
    description       String
    benefits          String[]
    riskLevel         RiskLevel
    fees              Json // { managementFee: 0.5, exitFee: 1.0, etc }

    // Token Allocation
    fixedTokens       Int @default(0) // Fixed tokens granted upon investment
    minPeriodicTokens Int @default(5) // Minimum random tokens per payment
    maxPeriodicTokens Int @default(50) // Maximum random tokens per payment

    metadata Json? // Additional plan metadata
    isActive Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    investments Investment[]

    @@map("investment_plans")
}

model Investment {
    id     String @id @default(cuid())
    userId String
    planId String

    // Investment Details
    amountInvested    Float
    currentValue      Float
    returns           Float
    returnsPercentage Float
    maturityDate      DateTime
    nextSipDate       DateTime?
    sipAmount         Float?
    swpAmount         Float?

    // Status
    status InvestmentStatus @default(ACTIVE)

    // Metadata
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
    plan         InvestmentPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
    transactions Transaction[]

    @@index([userId])
    @@index([planId])
    @@index([status])
    @@map("investments")
}

model Transaction {
    id           String  @id @default(cuid())
    userId       String
    investmentId String?

    // Transaction Details
    type             TransactionType
    amount           Float
    fee              Float             @default(0)
    status           TransactionStatus @default(PENDING)
    paymentMethod    String?
    paymentReference String?

    // Razorpay Fields
    razorpayOrderId   String? @unique
    razorpayPaymentId String? @unique
    razorpaySignature String?

    // Metadata
    description String?
    metadata    Json?

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    processedAt DateTime?

    // Relations
    user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    investment Investment? @relation(fields: [investmentId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([investmentId])
    @@index([status])
    @@index([type])
    @@index([razorpayOrderId])
    @@index([razorpayPaymentId])
    @@map("transactions")
}

model Notification {
    id     String @id @default(cuid())
    userId String

    // Notification Content
    title    String
    body     String
    type     NotificationType
    category NotificationCategory

    // Delivery
    isRead     Boolean   @default(false)
    isPushSent Boolean   @default(false)
    pushSentAt DateTime?

    // Metadata
    data      Json? // Additional notification data
    expiresAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([isRead])
    @@index([type])
    @@index([category])
    @@map("notifications")
}

model Device {
    id     String @id @default(cuid())
    userId String

    // Device Information
    deviceToken String         @unique
    platform    DevicePlatform
    deviceId    String
    deviceName  String?
    appVersion  String?
    osVersion   String?

    // Status
    isActive     Boolean  @default(true)
    lastActiveAt DateTime @default(now())

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([deviceToken])
    @@index([platform])
    @@map("devices")
}

model OtpVerification {
    id     String  @id @default(cuid())
    userId String?

    // OTP Details
    email   String?
    phone   String?
    otp     String
    type    OtpType
    purpose OtpPurpose

    // Status
    isVerified  Boolean @default(false)
    isExpired   Boolean @default(false)
    attempts    Int     @default(0)
    maxAttempts Int     @default(3)

    // Timing
    expiresAt  DateTime
    verifiedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([email])
    @@index([phone])
    @@index([type])
    @@index([purpose])
    @@map("otp_verifications")
}

model AuditLog {
    id     String  @id @default(cuid())
    userId String?

    // Audit Information
    action     String
    resource   String
    resourceId String?
    oldValues  Json?
    newValues  Json?

    // Context
    ipAddress String?
    userAgent String?
    metadata  Json?

    createdAt DateTime @default(now())

    // Relations
    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([action])
    @@index([resource])
    @@index([createdAt])
    @@map("audit_logs")
}

model PortfolioSnapshot {
    id     String @id @default(cuid())
    userId String

    // Portfolio Metrics
    totalInvested          Float
    currentValue           Float
    totalReturns           Float
    totalReturnsPercentage Float
    tokenBalance           Float @default(0)

    // Metadata
    snapshotDate DateTime @default(now())
    createdAt    DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([snapshotDate])
    @@map("portfolio_snapshots")
}

model TokenTransaction {
    id     String @id @default(cuid())
    userId String

    // Token Transaction Details
    type        TokenTransactionType
    amount      Int // positive for credit, negative for debit
    balance     Int // balance after transaction
    source      String // "investment_signup", "periodic_payment", "referral", "bonus", etc.
    description String?

    // Relations
    investmentId String?
    planId       String?

    // Metadata
    metadata  Json?
    createdAt DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([type])
    @@index([createdAt])
    @@map("token_transactions")
}

// Enums
enum KycStatus {
    PENDING
    IN_REVIEW
    APPROVED
    REJECTED
    INCOMPLETE
}

enum InvestmentType {
    LUMP_SUM
    SIP
    SWP
}

enum RiskLevel {
    LOW
    MEDIUM
    HIGH
}

enum InvestmentStatus {
    ACTIVE
    MATURED
    WITHDRAWN
    PAUSED
    CANCELLED
}

enum TransactionType {
    INVESTMENT
    WITHDRAWAL
    SIP_PAYMENT
    SWP_PAYOUT
    FEE
    REFUND
    DIVIDEND
}

enum TransactionStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
    CANCELLED
    REFUNDED
}

enum NotificationType {
    INFO
    SUCCESS
    WARNING
    ERROR
    PROMOTIONAL
}

enum NotificationCategory {
    INVESTMENT
    TRANSACTION
    KYC
    SECURITY
    SYSTEM
    MARKETING
}

enum DevicePlatform {
    IOS
    ANDROID
    WEB
}

enum OtpType {
    EMAIL
    SMS
}

enum OtpPurpose {
    REGISTRATION
    LOGIN
    PASSWORD_RESET
    TRANSACTION_VERIFICATION
    KYC_VERIFICATION
    WITHDRAWAL
}

enum TokenTransactionType {
    CREDIT
    DEBIT
    INVESTMENT_SIGNUP
    PERIODIC_PAYMENT
    REFERRAL_BONUS
    PROMOTIONAL
    REDEMPTION
    EXPIRY
    ADJUSTMENT
}

// NEW ENUMS FOR COURSES, CONSULTANCY, AND CHANNELS

enum CourseType {
    BOOTCAMP
    COURSE
    WORKSHOP
}

enum EnrollmentStatus {
    PENDING
    ACTIVE
    COMPLETED
    CANCELLED
    EXPIRED
}

enum ConsultancyType {
    SUBSCRIPTION  // Monthly/recurring subscription
    ONE_TIME      // One-time purchase
    SESSION       // Per-session booking
}

enum SubscriptionStatus {
    PENDING
    ACTIVE
    PAUSED
    CANCELLED
    EXPIRED
}

enum SessionStatus {
    SCHEDULED
    IN_PROGRESS
    COMPLETED
    CANCELLED
    NO_SHOW
}

enum ChannelType {
    COURSE      // Course announcement channel
    CONSULTANCY // Consultancy service channel
}

enum PostType {
    ANNOUNCEMENT
    STOCK_TIP
    MEETING_LINK
    RESOURCE
}

// NEW MODELS FOR COURSES, CONSULTANCY, AND CHANNELS

model Course {
    id          String   @id @default(cuid())
    title       String
    description String

    // Course Details
    thumbnail   String?     // URL to course image
    type        CourseType  // BOOTCAMP, COURSE, WORKSHOP
    category    String      // e.g., "Stock Trading", "Technical Analysis"
    duration    Int         // Duration in days
    startDate   DateTime?   // When course starts (null = on-demand)
    endDate     DateTime?

    // Pricing
    price       Float
    currency    String   @default("INR")

    // Status
    isActive    Boolean  @default(true)
    maxStudents Int?     // null = unlimited

    // Metadata
    syllabus    Json?    // Course curriculum structure
    instructor  String?  // Instructor name
    metadata    Json?    // Additional course data

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    enrollments CourseEnrollment[]
    channel     Channel?

    @@index([type])
    @@index([category])
    @@index([isActive])
    @@map("courses")
}

model CourseEnrollment {
    id        String @id @default(cuid())
    userId    String
    courseId  String

    // Enrollment Status
    status    EnrollmentStatus @default(PENDING)

    // Payment Reference
    transactionId String? @unique
    amountPaid    Float

    // Progress
    progress      Int     @default(0) // 0-100 percentage
    completedAt   DateTime?

    // Timestamps
    enrolledAt DateTime @default(now())
    expiresAt  DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

    @@unique([userId, courseId])
    @@index([userId])
    @@index([courseId])
    @@index([status])
    @@map("course_enrollments")
}

model ConsultancyService {
    id          String @id @default(cuid())
    name        String
    description String

    // Service Type
    type        ConsultancyType  // SUBSCRIPTION, ONE_TIME, SESSION

    // Pricing
    price       Float
    currency    String  @default("INR")
    duration    Int?    // Duration in days for subscriptions

    // Features
    features    String[]  // List of included features

    // Status
    isActive    Boolean @default(true)

    // Metadata
    metadata    Json?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    subscriptions ConsultancySubscription[]
    channel       Channel?
    sessions      OneOnOneSession[]

    @@index([type])
    @@index([isActive])
    @@map("consultancy_services")
}

model ConsultancySubscription {
    id        String @id @default(cuid())
    userId    String
    serviceId String

    // Subscription Status
    status    SubscriptionStatus @default(PENDING)

    // Payment Reference
    transactionId String? @unique
    amountPaid    Float

    // Subscription Period
    startDate DateTime?
    endDate   DateTime?

    // Auto-renewal
    autoRenew Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    service ConsultancyService @relation(fields: [serviceId], references: [id], onDelete: Restrict)

    @@unique([userId, serviceId])
    @@index([userId])
    @@index([serviceId])
    @@index([status])
    @@map("consultancy_subscriptions")
}

model OneOnOneSession {
    id        String @id @default(cuid())
    userId    String
    serviceId String

    // Session Details
    scheduledAt   DateTime
    duration      Int      // Duration in minutes
    status        SessionStatus @default(SCHEDULED)

    // Meeting Details
    meetingLink   String?  // Zoom/Meet link
    notes         String?  // Session notes

    // Payment
    transactionId String? @unique
    amountPaid    Float

    // Timestamps
    completedAt   DateTime?
    cancelledAt   DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    service ConsultancyService @relation(fields: [serviceId], references: [id], onDelete: Restrict)

    @@index([userId])
    @@index([serviceId])
    @@index([scheduledAt])
    @@index([status])
    @@map("one_on_one_sessions")
}

model Channel {
    id          String @id @default(cuid())
    name        String
    description String?

    // Channel Type & Source
    type        ChannelType
    courseId    String?    @unique
    serviceId   String?    @unique

    // Settings
    isActive    Boolean @default(true)

    // Metadata
    thumbnail   String?
    metadata    Json?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    course  Course?             @relation(fields: [courseId], references: [id], onDelete: Cascade)
    service ConsultancyService? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    posts   ChannelPost[]

    @@index([type])
    @@index([isActive])
    @@map("channels")
}

model ChannelPost {
    id        String @id @default(cuid())
    channelId String

    // Post Content
    content   String    // Markdown content
    type      PostType  @default(ANNOUNCEMENT)

    // Attachments
    attachments Json?   // Array of { type, url, name }

    // Meeting/Event Details
    meetingLink String?
    eventTime   DateTime?

    // Admin who posted
    postedBy    String  // Admin user ID

    // Status
    isPinned    Boolean @default(false)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    channel   Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
    reactions PostReaction[]

    @@index([channelId])
    @@index([createdAt])
    @@index([isPinned])
    @@map("channel_posts")
}

model PostReaction {
    id     String @id @default(cuid())
    postId String
    userId String

    // Reaction
    emoji  String  // Unicode emoji character

    createdAt DateTime @default(now())

    // Relations
    post ChannelPost @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@unique([postId, userId, emoji])
    @@index([postId])
    @@index([userId])
    @@map("post_reactions")
}
