// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    // Pooled (PgBouncer) connection for serverless runtime — see .env.example.
    url       = env("DATABASE_URL")
    // Direct (non-pooled) connection used only for migrations.
    directUrl = env("DIRECT_URL")
}

model User {
    id       String  @id @default(cuid())
    email    String  @unique
    password String
    name     String?
    phone    String? @unique

    // KYC Information
    panNumber     String? @unique
    aadhaarNumber String? @unique
    address       String?
    city          String?
    state         String?
    pincode       String?
    dateOfBirth   String?

    // Nominee Details
    nomineeName     String?
    nomineeRelation String?
    nomineeDob      String?
    nomineeAddress  String?

    // Professional Information
    occupation   String?
    annualIncome String?

    // Bank Details
    bankAccount   String?
    ifscCode      String?
    bankName      String?
    accountHolder String?

    // Token Balance
    tokenBalance Int @default(0)

    // Status & Verification
    kycStatus        KycStatus @default(PENDING)
    emailVerified    Boolean   @default(false)
    phoneVerified    Boolean   @default(false)
    twoFactorEnabled Boolean   @default(false)
    isActive         Boolean   @default(true)
    preferredLanguage String    @default("en")

    // BSE Star MF
    bseUcc          String?  @unique   // Unique Client Code (assigned once per investor)
    bseUccStatus    String?            // UCC lifecycle: PENDING_VERIFICATION / ACTIVE / SUSPENDED (from add_ucc + webhook)
    fatcaRegistered Boolean  @default(false)

    // Refresh Token for JWT
    refreshToken String?

    // Metadata
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    lastLoginAt DateTime?

    // Relations
    investments        Investment[]
    transactions       Transaction[]
    notifications      Notification[]
    devices            Device[]
    otpVerifications   OtpVerification[]
    auditLogs          AuditLog[]
    portfolioSnapshots PortfolioSnapshot[]
    tokenTransactions  TokenTransaction[]

    // Relations for Courses, Consultancy, and Channels
    courseEnrollments        CourseEnrollment[]
    consultancySubscriptions ConsultancySubscription[]
    oneOnOneSessions         OneOnOneSession[]
    postComments             PostComment[]
    mfOrders                 MutualFundOrder[]
    mfHoldings               MfHolding[]
    bankMandates             BankMandate[]
    sipRegistrations         SipRegistration[]

    @@index([email])
    @@index([phone])
    @@index([panNumber])
    @@index([aadhaarNumber])
    @@map("users")
}

model InvestmentPlan {
    id                String         @id @default(cuid())
    name              String
    professionalTitle String
    type              InvestmentType
    interestRate      Float
    minimumInvestment Float
    maximumInvestment Float?
    lockInPeriod      Int // in months
    description       String
    benefits          String[]
    riskLevel         RiskLevel
    fees              Json // { managementFee: 0.5, exitFee: 1.0, etc }

    // Token Allocation
    fixedTokens       Int @default(0) // Fixed tokens granted upon investment
    minPeriodicTokens Int @default(5) // Minimum random tokens per payment
    maxPeriodicTokens Int @default(50) // Maximum random tokens per payment

    // Asset Allocation
    equityAllocation Float @default(0)
    debtAllocation   Float @default(0)
    goldAllocation   Float @default(0)
    cashAllocation   Float @default(0)

    metadata Json? // Additional plan metadata
    isActive Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    investments       Investment[]
    tokenTransactions TokenTransaction[]

    @@map("investment_plans")
}

model Investment {
    id     String @id @default(cuid())
    userId String
    planId String

    // Investment Details
    amountInvested    Float
    currentValue      Float
    returns           Float
    returnsPercentage Float
    maturityDate      DateTime
    nextSipDate       DateTime?
    sipAmount         Float?
    swpAmount         Float?

    // Status
    status InvestmentStatus @default(ACTIVE)

    // Metadata
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    plan              InvestmentPlan     @relation(fields: [planId], references: [id], onDelete: Restrict)
    transactions      Transaction[]
    tokenTransactions TokenTransaction[]

    @@index([userId])
    @@index([planId])
    @@index([status])
    @@map("investments")
}

model Transaction {
    id           String  @id @default(cuid())
    userId       String
    investmentId String?

    // Transaction Details
    type             TransactionType
    amount           Float
    fee              Float             @default(0)
    status           TransactionStatus @default(PENDING)
    paymentMethod    String?
    paymentReference String?

    // Payment Gateway Fields (Generic)
    pgOrderId   String? @unique
    pgPaymentId String? @unique
    pgSignature String?
    pgProvider  String? @default("CASHFREE")

    // Legacy Razorpay Fields (Kept for backward compatibility)
    razorpayOrderId   String? @unique
    razorpayPaymentId String? @unique
    razorpaySignature String?

    // Metadata
    description String?
    metadata    Json?

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    processedAt DateTime?

    // Relations
    user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    investment        Investment?        @relation(fields: [investmentId], references: [id], onDelete: SetNull)
    tokenTransactions TokenTransaction[]

    @@index([userId])
    @@index([investmentId])
    @@index([status])
    @@index([type])
    @@index([pgOrderId])
    @@index([pgPaymentId])
    @@index([razorpayOrderId])
    @@index([razorpayPaymentId])
    @@map("transactions")
}

model Notification {
    id     String @id @default(cuid())
    userId String

    // Notification Content
    title    String
    body     String
    type     NotificationType
    category NotificationCategory

    // Delivery
    isRead     Boolean   @default(false)
    isPushSent Boolean   @default(false)
    pushSentAt DateTime?

    // Metadata
    data      Json? // Additional notification data
    expiresAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([isRead])
    @@index([type])
    @@index([category])
    @@map("notifications")
}

model Device {
    id     String @id @default(cuid())
    userId String

    // Device Information
    deviceToken String         @unique
    platform    DevicePlatform
    deviceId    String
    deviceName  String?
    appVersion  String?
    osVersion   String?

    // Status
    isActive     Boolean  @default(true)
    lastActiveAt DateTime @default(now())

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([deviceToken])
    @@index([platform])
    @@map("devices")
}

model OtpVerification {
    id     String  @id @default(cuid())
    userId String?

    // OTP Details
    email   String?
    phone   String?
    otp     String
    type    OtpType
    purpose OtpPurpose

    // Status
    isVerified  Boolean @default(false)
    isExpired   Boolean @default(false)
    attempts    Int     @default(0)
    maxAttempts Int     @default(3)

    // Timing
    expiresAt  DateTime
    verifiedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([email])
    @@index([phone])
    @@index([type])
    @@index([purpose])
    @@map("otp_verifications")
}

model AuditLog {
    id     String  @id @default(cuid())
    userId String?

    // Audit Information
    action     String
    resource   String
    resourceId String?
    oldValues  Json?
    newValues  Json?

    // Context
    ipAddress String?
    userAgent String?
    metadata  Json?

    createdAt DateTime @default(now())

    // Relations
    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([action])
    @@index([resource])
    @@index([createdAt])
    @@map("audit_logs")
}

model PortfolioSnapshot {
    id     String @id @default(cuid())
    userId String

    // Portfolio Metrics
    totalInvested          Float
    currentValue           Float
    totalReturns           Float
    totalReturnsPercentage Float
    tokenBalance           Float @default(0)

    // Metadata
    snapshotDate DateTime @default(now())
    createdAt    DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([snapshotDate])
    @@map("portfolio_snapshots")
}

model TokenTransaction {
    id     String @id @default(cuid())
    userId String

    // Token Transaction Details
    type        TokenTransactionType
    amount      Int // positive for credit, negative for debit
    balance     Int // balance after transaction
    source      String // "investment_signup", "periodic_payment", "referral", "bonus", etc.
    description String?

    // Relations
    investmentId  String?
    planId        String?
    transactionId String?

    // Metadata
    metadata  Json?
    createdAt DateTime @default(now())

    // Relations
    user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    investment  Investment?     @relation(fields: [investmentId], references: [id], onDelete: SetNull)
    plan        InvestmentPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
    transaction Transaction?    @relation(fields: [transactionId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([type])
    @@index([createdAt])
    @@map("token_transactions")
}

model Admin {
    id       String    @id @default(cuid())
    email    String    @unique
    password String
    name     String
    role     AdminRole @default(ADMIN)

    isActive  Boolean   @default(true)
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    lastLogin DateTime?

    @@map("admins")
}

model PlanMonthlyReturn {
    id     String @id @default(cuid())
    planId String

    // Return Configuration
    month           String // Format: YYYY-MM
    returnPercent   Float
    appliedAt       DateTime?
    appliedByUserId String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([planId, month])
    @@index([planId])
    @@index([month])
    @@map("plan_monthly_returns")
}

// Models for Courses, Consultancy, and Channels

model Coupon {
    id              String             @id @default(cuid())
    code            String             @unique
    description     String?
    discountPercent Float // 0-100
    applicableTo    CouponApplicableTo // COURSE, CONSULTANCY, BOTH

    // Scope — null means applicable to ALL courses/services
    courseId  String?
    serviceId String?

    // Limits
    isActive   Boolean   @default(true)
    usageLimit Int? // null = unlimited
    usageCount Int       @default(0)
    expiresAt  DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([code])
    @@index([isActive])
    @@map("coupons")
}

model Course {
    id          String @id @default(cuid())
    title       String
    description String

    // Course Details
    thumbnail String? // URL to course image
    type      CourseType // BOOTCAMP, COURSE, WORKSHOP
    category  String // e.g., "Stock Trading", "Technical Analysis"
    duration  Int // Duration in days
    startDate DateTime? // When course starts (null = on-demand)
    endDate   DateTime?

    // Pricing
    price    Float
    currency String @default("INR")

    // Status
    isActive    Boolean @default(true)
    maxStudents Int? // null = unlimited

    // KPI & Stats (admin-controlled metrics)
    totalLessons      Int? // Total lesson count
    totalModules      Int? // Total module count
    averageRating     Float? @default(4.9) // Average course rating
    estimatedStudents Int? // Display student count (for marketing, not actual enrollments)

    // Course Details (what's included, etc.)
    whatsIncluded String[] @default([]) // Features/benefits included in course
    disclaimer    String? // Legal disclaimer text

    // Metadata
    syllabus   Json? // Course curriculum structure
    instructor String? // Instructor name
    metadata   Json? // Additional course data

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    enrollments CourseEnrollment[]
    channel     Channel?
    coursePages  CoursePage[]
    webinars     Webinar[]

    @@index([type])
    @@index([category])
    @@index([isActive])
    @@map("courses")
}

model CourseEnrollment {
    id       String @id @default(cuid())
    userId   String
    courseId String

    // Enrollment Status
    status EnrollmentStatus @default(PENDING)

    // Payment Reference
    transactionId String? @unique
    amountPaid    Float

    // Coupon
    couponCode     String?
    discountAmount Float   @default(0)

    // Progress
    progress    Int       @default(0) // 0-100 percentage
    completedAt DateTime?

    // Timestamps
    enrolledAt DateTime  @default(now())
    expiresAt  DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

    @@unique([userId, courseId])
    @@index([userId])
    @@index([courseId])
    @@index([status])
    @@map("course_enrollments")
}

model ConsultancyService {
    id          String @id @default(cuid())
    name        String
    description String

    // Service Type
    type ConsultancyType // SUBSCRIPTION, ONE_TIME, SESSION

    // Pricing
    price    Float
    currency String @default("INR")
    duration Int? // Duration in days for subscriptions

    // Features
    features String[] // List of included features

    // Status
    isActive Boolean @default(true)

    // Metadata
    metadata Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    subscriptions ConsultancySubscription[]
    channel       Channel?
    sessions      OneOnOneSession[]

    @@index([type])
    @@index([isActive])
    @@map("consultancy_services")
}

model ConsultancySubscription {
    id        String @id @default(cuid())
    userId    String
    serviceId String

    // Subscription Status
    status SubscriptionStatus @default(PENDING)

    // Payment Reference
    transactionId String? @unique
    amountPaid    Float

    // Coupon
    couponCode     String?
    discountAmount Float   @default(0)

    // Subscription Period
    startDate DateTime?
    endDate   DateTime?

    // Auto-renewal
    autoRenew Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    service ConsultancyService @relation(fields: [serviceId], references: [id], onDelete: Restrict)

    @@unique([userId, serviceId])
    @@index([userId])
    @@index([serviceId])
    @@index([status])
    @@map("consultancy_subscriptions")
}

model OneOnOneSession {
    id        String @id @default(cuid())
    userId    String
    serviceId String

    // Session Details
    scheduledAt DateTime
    duration    Int // Duration in minutes
    status      SessionStatus @default(SCHEDULED)

    // Meeting Details
    meetingLink String? // Zoom/Meet link
    notes       String? // Session notes

    // Payment
    transactionId String? @unique
    amountPaid    Float

    // Timestamps
    completedAt DateTime?
    cancelledAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    service ConsultancyService @relation(fields: [serviceId], references: [id], onDelete: Restrict)

    @@index([userId])
    @@index([serviceId])
    @@index([scheduledAt])
    @@index([status])
    @@map("one_on_one_sessions")
}

model Channel {
    id          String  @id @default(cuid())
    name        String
    description String?

    // Channel Type & Source
    type      ChannelType
    courseId  String?     @unique
    serviceId String?     @unique

    // Settings
    isActive Boolean @default(true)

    // Metadata
    thumbnail String?
    metadata  Json?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    course  Course?             @relation(fields: [courseId], references: [id], onDelete: Cascade)
    service ConsultancyService? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    posts   ChannelPost[]

    @@index([type])
    @@index([isActive])
    @@map("channels")
}

model ChannelPost {
    id        String @id @default(cuid())
    channelId String

    // Post Content
    content String // Markdown content
    type    PostType @default(ANNOUNCEMENT)

    // Attachments
    attachments Json? // Array of { type, url, name }

    // Meeting/Event Details
    meetingLink String?
    eventTime   DateTime?

    // Admin who posted
    postedBy String // Admin user ID

    // Status
    isPinned Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    channel   Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
    reactions PostReaction[]
    comments  PostComment[]

    @@index([channelId])
    @@index([createdAt])
    @@index([isPinned])
    @@map("channel_posts")
}

model PostReaction {
    id     String @id @default(cuid())
    postId String
    userId String

    // Reaction
    emoji String // Unicode emoji character

    createdAt DateTime @default(now())

    // Relations
    post ChannelPost @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@unique([postId, userId, emoji])
    @@index([postId])
    @@index([userId])
    @@map("post_reactions")
}

// Enums
enum AdminRole {
    ADMIN
    SUPER_ADMIN
}

enum KycStatus {
    PENDING
    IN_REVIEW
    APPROVED
    REJECTED
    INCOMPLETE
}

enum InvestmentType {
    LUMP_SUM
    SIP
    SWP
}

enum RiskLevel {
    LOW
    MEDIUM
    HIGH
}

enum InvestmentStatus {
    ACTIVE
    MATURED
    WITHDRAWN
    PAUSED
    CANCELLED
}

enum TransactionType {
    INVESTMENT
    WITHDRAWAL
    SIP_PAYMENT
    SWP_PAYOUT
    FEE
    REFUND
    DIVIDEND
    COURSE_ENROLLMENT
    CONSULTANCY_SUBSCRIPTION
}

enum TransactionStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
    CANCELLED
    REFUNDED
}

enum NotificationType {
    INFO
    SUCCESS
    WARNING
    ERROR
    PROMOTIONAL
}

enum NotificationCategory {
    INVESTMENT
    TRANSACTION
    KYC
    SECURITY
    SYSTEM
    MARKETING
}

enum DevicePlatform {
    IOS
    ANDROID
    WEB
}

enum OtpType {
    EMAIL
    SMS
}

enum OtpPurpose {
    REGISTRATION
    LOGIN
    PASSWORD_RESET
    TRANSACTION_VERIFICATION
    KYC_VERIFICATION
    WITHDRAWAL
}

enum TokenTransactionType {
    CREDIT
    DEBIT
    INVESTMENT_SIGNUP
    PERIODIC_PAYMENT
    REFERRAL_BONUS
    PROMOTIONAL
    REDEMPTION
    EXPIRY
    ADJUSTMENT
}

// Enums for Courses, Consultancy, and Channels

enum CouponApplicableTo {
    COURSE
    CONSULTANCY
    BOTH
}

enum CourseType {
    BOOTCAMP
    COURSE
    WORKSHOP
}

enum EnrollmentStatus {
    PENDING
    ACTIVE
    COMPLETED
    CANCELLED
    EXPIRED
}

enum ConsultancyType {
    SUBSCRIPTION // Monthly/recurring subscription
    ONE_TIME // One-time purchase
    SESSION // Per-session booking
}

enum SubscriptionStatus {
    PENDING
    ACTIVE
    PAUSED
    CANCELLED
    EXPIRED
}

enum SessionStatus {
    SCHEDULED
    IN_PROGRESS
    COMPLETED
    CANCELLED
    NO_SHOW
}

enum ChannelType {
    COURSE // Course announcement channel
    CONSULTANCY // Consultancy service channel
}

enum PostType {
    ANNOUNCEMENT
    STOCK_TIP
    MEETING_LINK
    RESOURCE
}

// ── BFSI Course Page CMS Models ──

model CoursePage {
    id       String @id @default(cuid())
    courseId String
    slug     String @unique // e.g., "bfsi-career-accelerator"

    // Page Content
    heroTitle    String // "CAREER ACCELERATOR"
    heroSubtitle String // "Launch your Banking, Finance..."
    heroCtaText  String @default("Enroll Now")
    heroCtaLink  String? // Optional override

    // Offer
    offerTitle       String?
    offerDescription String?
    offerPrice       Float? // Display price (original)
    offerSalePrice   Float? // Sale price
    offerValidTill   DateTime?
    offerBadgeText   String? // "Limited Time Offer"

    // Trust metrics
    trustMetrics Json? // [{ label: "Students", value: "5000+" }, ...]

    // Features grid
    features Json? // [{ icon: "...", title: "...", description: "..." }]

    // SEO
    metaTitle       String?
    metaDescription String?
    ogImage         String?

    // Active theme slug (references frontend theme configs)
    activeTheme String @default("bfsi-default")

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
    modules      CourseModule[]
    faqs         CourseFAQ[]
    instructors  CourseInstructor[]
    testimonials CourseTestimonial[]
    projects     CourseProject[]
    stages       CourseStage[]

    @@index([courseId])
    @@index([slug])
    @@index([isActive])
    @@map("course_pages")
}

model CourseModule {
    id          String @id @default(cuid())
    coursePageId String

    title       String   // "Banking Fundamentals"
    description String?  // Module description
    duration    String?  // "4 weeks"
    topics      String[] // ["KYC", "Account Types", ...]
    sortOrder   Int      @default(0)

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    coursePage CoursePage @relation(fields: [coursePageId], references: [id], onDelete: Cascade)

    @@index([coursePageId])
    @@index([sortOrder])
    @@map("course_modules")
}

model CourseFAQ {
    id          String @id @default(cuid())
    coursePageId String

    question  String
    answer    String
    sortOrder Int @default(0)

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    coursePage CoursePage @relation(fields: [coursePageId], references: [id], onDelete: Cascade)

    @@index([coursePageId])
    @@index([sortOrder])
    @@map("course_faqs")
}

model CourseInstructor {
    id          String @id @default(cuid())
    coursePageId String

    name       String
    title      String  // "Senior Banking Analyst"
    bio        String?
    imageUrl   String?
    linkedinUrl String?
    experience String? // "15+ years"
    speciality String? // "Credit Risk"
    sortOrder  Int     @default(0)

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    coursePage CoursePage @relation(fields: [coursePageId], references: [id], onDelete: Cascade)

    @@index([coursePageId])
    @@index([sortOrder])
    @@map("course_instructors")
}

model CourseTestimonial {
    id          String @id @default(cuid())
    coursePageId String

    studentName String
    role        String? // "Placed at HDFC Bank"
    content     String
    rating      Int     @default(5)
    imageUrl    String?
    videoUrl    String?
    sortOrder   Int     @default(0)

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    coursePage CoursePage @relation(fields: [coursePageId], references: [id], onDelete: Cascade)

    @@index([coursePageId])
    @@index([sortOrder])
    @@map("course_testimonials")
}

model CourseProject {
    id          String @id @default(cuid())
    coursePageId String

    title       String   // "Loan Processing System"
    description String
    category    String?  // "Banking", "Insurance"
    skills      String[] // ["Credit Analysis", "Risk Assessment"]
    sortOrder   Int      @default(0)

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    coursePage CoursePage @relation(fields: [coursePageId], references: [id], onDelete: Cascade)

    @@index([coursePageId])
    @@index([sortOrder])
    @@map("course_projects")
}

model CourseStage {
    id          String @id @default(cuid())
    coursePageId String

    title       String   // "Learn", "Internship", "Placement", "Career Growth"
    description String
    icon        String?  // Lucide icon name
    features    String[] // ["12 Modules", "Industry Projects", ...]
    stageNumber Int      // 1, 2, 3, 4

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    coursePage CoursePage @relation(fields: [coursePageId], references: [id], onDelete: Cascade)

    @@index([coursePageId])
    @@index([stageNumber])
    @@map("course_stages")
}

model PostComment {
    id        String   @id @default(cuid())
    postId    String
    userId    String
    content   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    post ChannelPost @relation(fields: [postId], references: [id], onDelete: Cascade)
    user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([postId])
    @@index([userId])
    @@map("post_comments")
}

model Webinar {
    id          String   @id @default(cuid())
    title       String
    description String?
    scheduledAt DateTime
    duration    Int // in minutes
    meetingLink String // Zoom/Google Meet link

    // courseId is optional. If null, it represents a global webinar.
    courseId String?
    course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([courseId])
    @@index([scheduledAt])
    @@map("webinars")
}

// ── BSE Star MF Models ──

model MutualFundOrder {
  id            String        @id @default(cuid())
  userId        String
  bseOrderNumber String?      @unique          // returned by BSE at order entry
  memOrdRefId   String        @unique          // our idempotency key (mem_ord_ref_id sent to BSE)
  side          MfOrderSide   @default(BUY)     // BUY (purchase) or SELL (redeem)
  schemeCode    String                          // BSE scheme code
  schemeName    String
  amount        Float?                          // required for BUY; optional for amount-based SELL
  units         Float?                          // SELL input or BUY allotment output
  allUnits      Boolean       @default(false)   // redeem-all flag
  type          MfOrderType   @default(LUMPSUM)
  status        MfOrderStatus @default(PENDING_PAYMENT)
  paymentUrl    String?                         // exchange PG redirect (transient; surfaced to app)
  paymentRefId  String?                         // from get_exchpg_service / send_payment_info
  bankTxnRef    String?                         // bank transaction reference
  folioNumber   String?                         // required for SELL; assigned post-allotment for BUY
  bseRemarks    String?                         // raw BSE message for ops/debugging
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("mutual_fund_orders")
}

// Derived from allotments (D5): our record of what a user owns and can sell.
model MfHolding {
  id          String   @id @default(cuid())
  userId      String
  ucc         String
  schemeCode  String
  schemeName  String
  folioNumber String
  units       Float
  avgCost     Float?
  lastNav     Float?
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ucc, schemeCode, folioNumber])
  @@index([userId])
  @@map("mf_holdings")
}

// Phase 2 stubs (models added now so migrations are additive later).
model BankMandate {
  id           String        @id @default(cuid())
  userId       String
  bseMandateId String?       @unique
  type         MandateType
  amountLimit  Float
  status       MandateStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_mandates")
}

model SipRegistration {
  id         String   @id @default(cuid())
  userId     String
  bseRegNo   String?  @unique
  schemeCode String
  amount     Float
  frequency  String
  mandateId  String?
  status     String   @default("PENDING")
  nextDebit  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sip_registrations")
}

model MfScheme {
  id            String   @id @default(cuid())
  schemeCode    String   @unique
  schemeName    String
  amcName       String?
  category      String?                          // Equity / Debt / Hybrid / ELSS
  isin          String?
  minPurchase   Float?
  sipAllowed    Boolean  @default(false)
  nav           Float?
  navDate       DateTime?
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@map("mf_schemes")
}

enum MfOrderType {
  LUMPSUM
  SIP
}

enum MfOrderSide {
  BUY
  SELL
}

enum MfOrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  ALLOTTED
  REDEEMED
  REJECTED
  CANCELLED
}

enum MandateType {
  ENACH
  UPI_AUTOPAY
  NACH
  XSIP
  ISIP
}

enum MandateStatus {
  PENDING
  ACTIVE
  REJECTED
  CANCELLED
}
