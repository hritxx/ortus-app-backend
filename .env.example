# Ortus backend environment — copy to .env and fill in real values. NEVER commit secrets.
# See docs: ortus-app/docs/2026-06-29-ec2-deployment-runbook.md (§6)

NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000,exp://,ortus-finance://

# Database (Neon) — pooled for runtime, direct for migrations
DATABASE_URL=postgresql://<user>:<pass>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://<user>:<pass>@<host>.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Auth / crypto
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=
ENCRYPTION_ALGORITHM=aes-256-gcm
BCRYPT_ROUNDS=12

# Payments
PAYMENT_GATEWAY=CASHFREE
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=TEST
# CASHFREE_RETURN_URL=https://api.<yourdomain>/payment-return   # optional https return page
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Redis (in-compose for BullMQ jobs)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Firebase (FCM) — keep the private key on ONE line with literal \n
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Email (Brevo) / OTP / SMS / misc
BREVO_API_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
FROM_EMAIL=no-reply@example.com
FROM_NAME=Ortus Finance
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=5
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
SENTRY_DSN=

# BSE Star MF (UAT). Real values go in .env (gitignored).
BSE_ENV=uat
BSE_MEMBER_CODE=
BSE_USER_ID=
BSE_PASSWORD=
BSE_SOAP_ORDER_URL=https://bsestarmfdemo.bseindia.com/...   # VERIFY: BSE PDF
BSE_REST_BASE_URL=https://bsestarmfdemo.bseindia.com/StarMFCommonAPI
